{
  "version": 2,
  "builds": [
    { "src": "api/chat.js",  "use": "@vercel/node" },
    { "src": "api/price.js", "use": "@vercel/node" },
    { "src": "api/sync.js",  "use": "@vercel/node" },
    { "src": "index.html",   "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat",  "dest": "/api/chat.js"  },
    { "src": "/api/price", "dest": "/api/price.js" },
    { "src": "/api/sync",  "dest": "/api/sync.js"  },
    { "src": "/(.*)",      "dest": "/index.html"   }
  ]
}
